# Copy to /workspace/gpu.env on the rented machine and edit as needed.

ROOT_DIR=/workspace/Open-Higgsfield-AI
WORKSPACE_DIR=/workspace
COMFY_DIR=/workspace/comfy/ComfyUI
BACKEND_VENV=/workspace/venvs/open-higgsfield-backend
COMFY_VENV=/workspace/venvs/comfyui
HF_HOME=/workspace/cache/huggingface
TORCH_HOME=/workspace/cache/torch
LOG_DIR=/workspace/logs
OUTPUT_DIR=/workspace/outputs
COMFY_PORT=8188
BACKEND_PORT=8000

# Keep runtime selection machine-local.
# Example:
# OPEN_HIGGSFIELD_VIDEO_COMMAND=python3 -m backend.runners.remote_video_runner --payload "{payload_path}" --output "{output_path}"
# OPEN_HIGGSFIELD_LIPSYNC_COMMAND=python3 -m backend.runners.remote_lipsync_runner --payload "{payload_path}" --output "{output_path}"
#
# ComfyUI bridge example:
# OPEN_HIGGSFIELD_VIDEO_COMMAND=python3 -m backend.runners.comfy_video_runner --payload "{payload_path}" --output "{output_path}"
# OPEN_HIGGSFIELD_LIPSYNC_COMMAND=python3 -m backend.runners.comfy_lipsync_runner --payload "{payload_path}" --output "{output_path}"
# OPEN_HIGGSFIELD_COMFY_BASE_URL=http://127.0.0.1:18188

OPEN_HIGGSFIELD_VIDEO_COMMAND=
OPEN_HIGGSFIELD_LIPSYNC_COMMAND=
OPEN_HIGGSFIELD_REMOTE_VIDEO_SUBMIT_URL=
OPEN_HIGGSFIELD_REMOTE_VIDEO_STATUS_URL_TEMPLATE=
OPEN_HIGGSFIELD_REMOTE_VIDEO_TOKEN=
OPEN_HIGGSFIELD_REMOTE_VIDEO_POLL_INTERVAL=2.0
OPEN_HIGGSFIELD_REMOTE_VIDEO_MAX_ATTEMPTS=300
OPEN_HIGGSFIELD_REMOTE_LIPSYNC_SUBMIT_URL=
OPEN_HIGGSFIELD_REMOTE_LIPSYNC_STATUS_URL_TEMPLATE=
OPEN_HIGGSFIELD_REMOTE_LIPSYNC_TOKEN=
OPEN_HIGGSFIELD_REMOTE_LIPSYNC_POLL_INTERVAL=2.0
OPEN_HIGGSFIELD_REMOTE_LIPSYNC_MAX_ATTEMPTS=300
OPEN_HIGGSFIELD_COMFY_BASE_URL=
OPEN_HIGGSFIELD_COMFY_TOKEN=
OPEN_HIGGSFIELD_COMFY_POLL_INTERVAL=2.0
OPEN_HIGGSFIELD_COMFY_MAX_ATTEMPTS=300
OPEN_HIGGSFIELD_COMFY_VIDEO_GENERATE_WORKFLOW=
OPEN_HIGGSFIELD_COMFY_VIDEO_ANIMATE_IMAGE_WORKFLOW=
OPEN_HIGGSFIELD_COMFY_VIDEO_TRANSFORM_WORKFLOW=
OPEN_HIGGSFIELD_COMFY_LIPSYNC_IMAGE_AUDIO_WORKFLOW=
OPEN_HIGGSFIELD_COMFY_LIPSYNC_VIDEO_AUDIO_WORKFLOW=
