# Optional runtime command configuration for local or remote worker execution.
# If unset, video and lipsync jobs fall back to the built-in placeholder runtime.
#
# Supported placeholders:
# - {job_id}
# - {payload_path}
# - {output_path}
#
# Example:
# OPEN_HIGGSFIELD_VIDEO_COMMAND='python3 -m backend.runners.video_runner --payload "{payload_path}" --output "{output_path}"'
# OPEN_HIGGSFIELD_LIPSYNC_COMMAND='python3 -m backend.runners.lipsync_runner --payload "{payload_path}" --output "{output_path}"'
#
# Remote bridge examples:
# OPEN_HIGGSFIELD_VIDEO_COMMAND='python3 -m backend.runners.remote_video_runner --payload "{payload_path}" --output "{output_path}"'
# OPEN_HIGGSFIELD_REMOTE_VIDEO_SUBMIT_URL='https://gpu.example.com/video/jobs'
# OPEN_HIGGSFIELD_REMOTE_VIDEO_STATUS_URL_TEMPLATE='https://gpu.example.com/video/jobs/{job_id}'
#
# OPEN_HIGGSFIELD_LIPSYNC_COMMAND='python3 -m backend.runners.remote_lipsync_runner --payload "{payload_path}" --output "{output_path}"'
# OPEN_HIGGSFIELD_REMOTE_LIPSYNC_SUBMIT_URL='https://gpu.example.com/lipsync/jobs'
# OPEN_HIGGSFIELD_REMOTE_LIPSYNC_STATUS_URL_TEMPLATE='https://gpu.example.com/lipsync/jobs/{job_id}'

OPEN_HIGGSFIELD_VIDEO_COMMAND=
OPEN_HIGGSFIELD_LIPSYNC_COMMAND=
OPEN_HIGGSFIELD_REMOTE_VIDEO_SUBMIT_URL=
OPEN_HIGGSFIELD_REMOTE_VIDEO_STATUS_URL_TEMPLATE=
OPEN_HIGGSFIELD_REMOTE_VIDEO_TOKEN=
OPEN_HIGGSFIELD_REMOTE_VIDEO_POLL_INTERVAL=
OPEN_HIGGSFIELD_REMOTE_VIDEO_MAX_ATTEMPTS=
OPEN_HIGGSFIELD_REMOTE_LIPSYNC_SUBMIT_URL=
OPEN_HIGGSFIELD_REMOTE_LIPSYNC_STATUS_URL_TEMPLATE=
OPEN_HIGGSFIELD_REMOTE_LIPSYNC_TOKEN=
OPEN_HIGGSFIELD_REMOTE_LIPSYNC_POLL_INTERVAL=
OPEN_HIGGSFIELD_REMOTE_LIPSYNC_MAX_ATTEMPTS=
