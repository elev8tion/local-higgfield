{
  "metadata": {
    "description": "Starter template for portrait lipsync via ComfyUI. Replace with your exported MuseTalk/LatentSync workflow.",
    "output_node_ids": [
      "save_video"
    ]
  },
  "prompt": {
    "load_image": {
      "inputs": {
        "image": "{{assets.image_path}}"
      },
      "class_type": "LoadImage"
    },
    "load_audio": {
      "inputs": {
        "audio": "{{assets.audio_path}}"
      },
      "class_type": "LoadAudio"
    },
    "save_video": {
      "inputs": {
        "filename_prefix": "{{output.stem}}"
      },
      "class_type": "VHS_VideoCombine"
    }
  }
}
