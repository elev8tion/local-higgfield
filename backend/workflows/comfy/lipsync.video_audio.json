{
  "metadata": {
    "description": "Starter template for video lipsync via ComfyUI. Replace with your exported LatentSync workflow.",
    "output_node_ids": [
      "save_video"
    ]
  },
  "prompt": {
    "load_video": {
      "inputs": {
        "video": "{{assets.video_path}}"
      },
      "class_type": "VHS_LoadVideo"
    },
    "load_audio": {
      "inputs": {
        "audio": "{{assets.audio_path}}"
      },
      "class_type": "LoadAudio"
    },
    "save_video": {
      "inputs": {
        "filename_prefix": "{{output.stem}}"
      },
      "class_type": "VHS_VideoCombine"
    }
  }
}
